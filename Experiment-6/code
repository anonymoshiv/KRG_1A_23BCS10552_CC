#include <iostream>
#include<algorithm>
#include<vector>
#include<queue>
using namespace std;

int main() {
    int n;
    cin >> n;
    vector<vector<int>> courses = {{1,0},{2,0},{3,1},{3,2}};
    int v = courses.size();
    vector<vector<int>>adj;
    vector<int>in;
    for(int i = 0;i<v;i++){
        adj[courses[i][1]].push_back(courses[i][0]);
        in[courses[i][0]]++;
    }
    queue<int>q;
    for(int i = 0;i<in.size();i++){
        if(in[i] == 0)q.push(in[i]);
    }
    vector<int>res;
    while(!q.empty()){
        res.push_back(q.front());
        for(int  i = 0;i<adj[q.front()].size();i++){
            in[adj[q.front()][i]]--;
            if(in[adj[q.front()][i]] == 0) q.push(adj[q.front()][i]);
        }
        q.pop();
    }
    for(int i = 0;i<res.size();i++){
        cout << res[i] << ' ';
    }
    return 0;
}
